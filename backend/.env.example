# Copy to backend/.env and fill in.

# Giphy API key for celebration GIFs.
# Get a free one at https://developers.giphy.com/dashboard/
# Without it, /api/giphy/celebration returns 503 and the celebration
# overlay just plays confetti + sound (no GIF).
GIPHY_API_KEY=

# Wholesome search term seeded into Giphy. Default: high five.
GIPHY_QUERY=high five

# Comma-separated list of webhook target URLs. Empty = events are recorded
# in the webhook_events table but no HTTP delivery is attempted.
# Example for a local n8n: WEBHOOK_URL=http://localhost:5678/webhook/abc123
WEBHOOK_URL=

# Minutes before a block's deadline to fire block.deadline_approaching.
WEBHOOK_APPROACH_MINUTES=15
